# =============================================
# COPY FILE INI KE .env.local (JANGAN COMMIT!)
# =============================================

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_dengan_perintah_openssl_rand_base64_32

# --- Google OAuth ---
# Buat di: https://console.cloud.google.com > APIs > Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx

# --- Firebase Admin SDK (server-side) ---
# Dari Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=jamaah-talent-hub
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@jamaah-talent-hub.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxxxxx\n-----END PRIVATE KEY-----\n"

# --- Firebase Client (public, aman di frontend) ---
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy-xxxxxxxxxxxxx
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=jamaah-talent-hub.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=jamaah-talent-hub
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=jamaah-talent-hub.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:xxxxxxxx
